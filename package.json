{
  "name": "expo-app",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build:server": "npx tsc -p tsconfig.server.json && npx tsc-alias -p tsconfig.server.json",
    "build": "npm run build:server",
    "render-build": "npm run build",
    "render-start": "node -r dotenv/config dist/server.js",
    "start:server": "node -r dotenv/config dist/server.js",
    "start": "expo start -c",
    "start:localhost": "expo start --localhost --port 8081 -c",
    "start:lan": "expo start --lan -c",
    "start:tunnel": "expo start --tunnel -c",
    "start-web": "expo start --web -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint"
  },
  "dependencies": {
