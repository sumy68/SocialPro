{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "src/server.ts",
    "src/hono.ts",
    "src/backend/**/*.ts",
    "src/api/**/*.ts"
  ],
  "exclude": [
    "src/utils/**",          // client-only utils (z.B. expo AuthSession)
    "src/app/**",
    "src/components/**",
    "src/(tabs)/**"
  ]
}
