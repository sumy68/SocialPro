{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "jsx": "react-jsx",
    "lib": ["ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "types": ["expo", "react", "react-native"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/contexts/*": ["contexts/*"],
      "@/hooks/*": ["hooks/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "expo-env.d.ts", ".expo/types/**/*.ts"],
  "exclude": ["node_modules", "dist", "ios", "android"]
}
