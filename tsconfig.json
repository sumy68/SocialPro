{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*"]
    },
    "types": ["expo-router"],            // bessere Route-Typen
    "moduleResolution": "Bundler",       // TS5 + RN/Expo friendly
    "jsx": "react-jsx",                  // moderne JSX-Transform
    "noEmit": true,                      // wir emitten eh nix (Babel)
    "isolatedModules": true,             // für Babel/metro
    "skipLibCheck": true,                // schneller, weniger Lärm
    "resolveJsonModule": true            // falls du JSON importierst
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
