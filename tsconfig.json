{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,

    // ✅ Alias bleibt wie bei dir
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@rork/toolkit-sdk": ["mocks/rork-toolkit-sdk"]
    },

    // ✅ Wichtig für server.ts (Node-APIs wie process, __dirname, etc.)
    "types": ["node"],

    // ✅ Saubere ESM-Auflösung (passt gut zu tsx & top-level await)
    "module": "ESNext",
    "moduleResolution": "Node",

    // ✅ Moderne Syntax zur Laufzeit (Node 18+/Render ok)
    "target": "ES2022",

    // Hilfreich für schnellere Builds und weniger Friktion
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "mocks/**/*",
    "types/**/*",
    "app/**/*",
    "src/**/*",
    "server.ts"
  ]
}
