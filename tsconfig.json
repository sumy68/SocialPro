{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,                // schnellerer Build, ignoriert Tippfehler in node_modules
    "noUncheckedIndexedAccess": true,    // sicherer bei Array-/Objekt-Zugriffen
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
