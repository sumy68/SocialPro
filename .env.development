EXPO_PUBLIC_APP_URL=https://socialpro-fnvo.onrender.com
EXPO_PUBLIC_DEMO_MODE=0
EXPO_PUBLIC_SCHEME=myapp

# Wähle EINE Redirect-Variante und halte sie überall gleich (Backend + OAuth-Provider):

# Variante A (Expo-Standard):
EXPO_PUBLIC_OAUTH_REDIRECT_PATH=/--/oauthredirect

# ODER Variante B (nur wenn dein Backend/Provider GENAU das erwartet):
# EXPO_PUBLIC_OAUTH_REDIRECT_PATH=/auth/callback
